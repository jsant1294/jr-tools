{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/es", "destination": "/es.html" },
    { "source": "/en", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}